# Copy to .env.<instance> and adjust. Do not put tokens here; lark-cli stores auth separately.

# Leave empty to auto-detect the repository root as two directories above this tool.
# Example: WORKSPACE_ROOT=/Users/me/project
WORKSPACE_ROOT=
MENTION_NAME=OnCall
# Poll interval (launchd StartInterval). Lightweight poll runs every N seconds; Cursor only on @ hit.
SCAN_INTERVAL_SECONDS=60
# Message lookback window (minutes). Use ~2–3x SCAN_INTERVAL_SECONDS/60.
WINDOW_MINUTES=3
HANDLED_FILE=/tmp/lark-oncall-agent/handled_at_msg_ids.txt
LOG_DIR=/tmp/lark-oncall-agent
REPLY_MODE=send
# Long trace replies go to thread (recommended). feishu-reply-markdown.sh reads this default.
REPLY_IN_THREAD=true

# Use chat IDs when you already know them. This avoids chat search on every run.
# Supported forms:
# TARGET_CHAT_IDS_JSON='["oc_xxx","oc_yyy"]'
# TARGET_CHAT_IDS_JSON='[{"name":"Engineering On-call","chat_id":"oc_xxx"},{"name":"Platform Alerts","chat_id":"oc_yyy"}]'
TARGET_CHAT_IDS_JSON='[]'
TARGET_CHAT_NAMES_JSON='["Engineering On-call","Platform Alerts"]'

# Cursor Agent CLI settings.
CURSOR_MODEL=composer-2.5
CURSOR_OUTPUT_FORMAT=text
CURSOR_FORCE=false
CURSOR_SANDBOX=

# Optional: path to your logs query CLI (see setup-logs-permissions.sh)
# LOGS_CLIENT=${HOME}/.cursor/skills/your-logs-skill/scripts/logs_client.py
